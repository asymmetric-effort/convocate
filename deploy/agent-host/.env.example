# Agent host environment configuration
#
# CONVOCATE_CONTROL_URL: Router API mTLS endpoint on the control plane.
CONVOCATE_CONTROL_URL=https://router.example.com:8443

# CONVOCATE_CONTROL_CA: path to the control plane CA trust bundle.
CONVOCATE_CONTROL_CA=/etc/convocate/control-ca.pem

# CONVOCATE_HOST_CERT: path to this host's mTLS client certificate.
CONVOCATE_HOST_CERT=/etc/convocate/host.pem

# CONVOCATE_HOST_ID: unique identifier for this agent host (must match the cert).
CONVOCATE_HOST_ID=agent-a
