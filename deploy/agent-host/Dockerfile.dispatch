FROM --platform=linux/amd64 ubuntu:latest AS builder

ARG GO_VERSION=1.26.3
ARG TARGETARCH

RUN apt-get update && \
    apt-get install -y --no-install-recommends curl ca-certificates && \
    rm -rf /var/lib/apt/lists/* && \
    curl -fsSL "https://go.dev/dl/go${GO_VERSION}.linux-amd64.tar.gz" \
      | tar -xz -C /usr/local

ENV PATH="/usr/local/go/bin:${PATH}"

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .

ARG VERSION=dev
RUN CGO_ENABLED=0 GOARCH=${TARGETARCH:-amd64} go build -trimpath \
    -ldflags "-s -w -X main.Version=${VERSION}" \
    -o /out/convocate-dispatch ./cmd/convocate-dispatch/

FROM gcr.io/distroless/static-debian12

COPY --from=builder /out/convocate-dispatch /usr/local/bin/convocate-dispatch

ENTRYPOINT ["/usr/local/bin/convocate-dispatch"]
