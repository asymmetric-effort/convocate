FROM --platform=linux/amd64 ubuntu:latest

ARG VERSION=dev
ARG DEV_MOCK_CLAUDE=0

LABEL org.opencontainers.image.title="convocate-agent" \
      org.opencontainers.image.version="${VERSION}" \
      org.opencontainers.image.description="Convocate Agent Container (per-project)"

RUN apt-get update && apt-get install -y \
    git \
    curl \
    openssh-client \
    && rm -rf /var/lib/apt/lists/*

# gh CLI — install from official tarball
RUN GH_VERSION="2.74.0" && \
    curl -fsSL "https://github.com/cli/cli/releases/download/v${GH_VERSION}/gh_${GH_VERSION}_linux_amd64.tar.gz" \
    | tar -xz -C /usr/local --strip-components=1

# Claude Code (skipped when DEV_MOCK_CLAUDE=1)
RUN if [ "$DEV_MOCK_CLAUDE" = "0" ]; then \
      curl -fsSL https://deb.nodesource.com/setup_24.x | bash - && \
      apt-get install -y nodejs && \
      npm install -g @anthropic-ai/claude-code && \
      rm -rf /var/lib/apt/lists/*; \
    fi

# Go wrapper — the container entrypoint (cross-compiled for amd64)
COPY build/convocate-agent-wrapper /usr/local/bin/convocate-agent-wrapper

# mock-claude for dev/e2e testing
COPY build/mock-claude /usr/local/bin/mock-claude

RUN useradd -m -s /bin/bash agent
USER agent
WORKDIR /workspace

VOLUME ["/workspace"]

ENTRYPOINT ["/usr/local/bin/convocate-agent-wrapper"]
