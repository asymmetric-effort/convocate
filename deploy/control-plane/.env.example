# Control plane environment configuration
#
# CONVOCATE_PUBLIC_URL: hostname GitHub Actions and operators use to reach the
# Router API. Becomes a SAN on the Router API's TLS certificate and the base
# URL the Web UI embeds in operator-facing links.
CONVOCATE_PUBLIC_URL=https://router.example.com

# CONVOCATE_OPENBAO_UNSEAL: path to the sealed bootstrap key file inside the
# container (supplied as a Docker secret).
CONVOCATE_OPENBAO_UNSEAL=/run/secrets/openbao-unseal
