FROM gcr.io/distroless/base-debian12

ARG VERSION=dev

LABEL org.opencontainers.image.title="convocate-router" \
      org.opencontainers.image.version="${VERSION}" \
      org.opencontainers.image.description="Convocate Router API + Web UI + CLI"

COPY build/convocate-router /usr/local/bin/convocate-router
COPY build/convocate-cli /usr/local/bin/convocate-cli

EXPOSE 443 8443

ENTRYPOINT ["/usr/local/bin/convocate-router"]
