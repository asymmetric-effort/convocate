FROM --platform=linux/amd64 ubuntu:latest

RUN sed -i 's/Components: main.*/Components: main/' /etc/apt/sources.list.d/*.sources 2>/dev/null; sed -i '/universe\|multiverse\|restricted/d' /etc/apt/sources.list 2>/dev/null
RUN apt-get update && \
    apt-get install -y --no-install-recommends redis-server && \
    rm -rf /var/lib/apt/lists/* && \
    mkdir -p /data && chown redis:redis /data

USER redis
WORKDIR /data
EXPOSE 6379

ENTRYPOINT ["redis-server"]
