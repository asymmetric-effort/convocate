{
  "uid": "svr00-system",
  "id": null,
  "title": "svr00 - System Stats",
  "description": "Server system statistics for svr00 using node_exporter metrics",
  "tags": ["convocate", "svr00", "system"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "schemaVersion": 39,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["10s", "30s", "1m", "5m", "15m"]
  },
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(node_uname_info, instance)",
        "current": {},
        "refresh": 2,
        "sort": 1,
        "includeAll": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Uptime",
      "description": "System uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 3600 },
              { "color": "green", "value": 86400 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "time() - node_boot_time_seconds{instance=~\"$instance\"}",
          "legendFormat": "Uptime",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "System Load",
      "description": "System load averages (1m, 5m, 15m)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "orange", "value": 4 },
              { "color": "red", "value": 8 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "node_load1{instance=~\"$instance\"}",
          "legendFormat": "1m",
          "refId": "A"
        },
        {
          "expr": "node_load5{instance=~\"$instance\"}",
          "legendFormat": "5m",
          "refId": "B"
        },
        {
          "expr": "node_load15{instance=~\"$instance\"}",
          "legendFormat": "15m",
          "refId": "C"
        }
      ]
    },
    {
      "id": 3,
      "title": "Memory Usage",
      "description": "Current memory utilization",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "orange", "value": 0.85 },
              { "color": "red", "value": 0.95 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "1 - (node_memory_MemAvailable_bytes{instance=~\"$instance\"} / node_memory_MemTotal_bytes{instance=~\"$instance\"})",
          "legendFormat": "Used",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "CPU Usage",
      "description": "Current CPU utilization",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "orange", "value": 0.85 },
              { "color": "red", "value": 0.95 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "1 - avg(rate(node_cpu_seconds_total{instance=~\"$instance\",mode=\"idle\"}[5m]))",
          "legendFormat": "CPU Used",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "CPU Usage by Mode",
      "description": "CPU utilization breakdown by mode (user, system, idle, iowait)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 30,
            "stacking": { "mode": "normal" },
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "expr": "avg by (mode) (rate(node_cpu_seconds_total{instance=~\"$instance\",mode=~\"user|system|idle|iowait\"}[5m]))",
          "legendFormat": "{{mode}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Memory Breakdown",
      "description": "Memory usage breakdown (used, free, cached, buffers)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 30,
            "stacking": { "mode": "normal" },
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes{instance=~\"$instance\"} - node_memory_MemFree_bytes{instance=~\"$instance\"} - node_memory_Cached_bytes{instance=~\"$instance\"} - node_memory_Buffers_bytes{instance=~\"$instance\"}",
          "legendFormat": "Used",
          "refId": "A"
        },
        {
          "expr": "node_memory_Buffers_bytes{instance=~\"$instance\"}",
          "legendFormat": "Buffers",
          "refId": "B"
        },
        {
          "expr": "node_memory_Cached_bytes{instance=~\"$instance\"}",
          "legendFormat": "Cached",
          "refId": "C"
        },
        {
          "expr": "node_memory_MemFree_bytes{instance=~\"$instance\"}",
          "legendFormat": "Free",
          "refId": "D"
        }
      ]
    },
    {
      "id": 7,
      "title": "Disk Usage by Mount",
      "description": "Disk space utilization per mount point",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Used %" },
            "properties": [
              { "id": "unit", "value": "percentunit" },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "color": "green", "value": null },
                    { "color": "yellow", "value": 0.7 },
                    { "color": "orange", "value": 0.85 },
                    { "color": "red", "value": 0.95 }
                  ]
                }
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Total" },
            "properties": [{ "id": "unit", "value": "bytes" }]
          },
          {
            "matcher": { "id": "byName", "options": "Used" },
            "properties": [{ "id": "unit", "value": "bytes" }]
          },
          {
            "matcher": { "id": "byName", "options": "Available" },
            "properties": [{ "id": "unit", "value": "bytes" }]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Used %", "desc": true }]
      },
      "transformations": [
        {
          "id": "merge",
          "options": {}
        }
      ],
      "targets": [
        {
          "expr": "node_filesystem_size_bytes{instance=~\"$instance\",fstype!~\"tmpfs|overlay|squashfs\"}",
          "legendFormat": "",
          "refId": "A",
          "format": "table",
          "instant": true
        },
        {
          "expr": "node_filesystem_size_bytes{instance=~\"$instance\",fstype!~\"tmpfs|overlay|squashfs\"} - node_filesystem_avail_bytes{instance=~\"$instance\",fstype!~\"tmpfs|overlay|squashfs\"}",
          "legendFormat": "",
          "refId": "B",
          "format": "table",
          "instant": true
        },
        {
          "expr": "node_filesystem_avail_bytes{instance=~\"$instance\",fstype!~\"tmpfs|overlay|squashfs\"}",
          "legendFormat": "",
          "refId": "C",
          "format": "table",
          "instant": true
        },
        {
          "expr": "1 - (node_filesystem_avail_bytes{instance=~\"$instance\",fstype!~\"tmpfs|overlay|squashfs\"} / node_filesystem_size_bytes{instance=~\"$instance\",fstype!~\"tmpfs|overlay|squashfs\"})",
          "legendFormat": "",
          "refId": "D",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "id": 8,
      "title": "Disk I/O",
      "description": "Disk read/write operations per second",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "iops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "expr": "rate(node_disk_reads_completed_total{instance=~\"$instance\"}[5m])",
          "legendFormat": "{{device}} reads/s",
          "refId": "A"
        },
        {
          "expr": "rate(node_disk_writes_completed_total{instance=~\"$instance\"}[5m])",
          "legendFormat": "{{device}} writes/s",
          "refId": "B"
        }
      ]
    },
    {
      "id": 9,
      "title": "Network Traffic",
      "description": "Network bytes received and transmitted per interface",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "lineWidth": 1
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*transmit.*" },
            "properties": [
              { "id": "custom.transform", "value": "negative-Y" }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{instance=~\"$instance\",device!=\"lo\"}[5m])",
          "legendFormat": "{{device}} receive",
          "refId": "A"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{instance=~\"$instance\",device!=\"lo\"}[5m])",
          "legendFormat": "{{device}} transmit",
          "refId": "B"
        }
      ]
    }
  ]
}
