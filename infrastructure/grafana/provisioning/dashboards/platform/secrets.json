{
  "uid": "secrets-openbao",
  "id": null,
  "title": "Secrets - OpenBao",
  "description": "OpenBao (Vault-compatible) monitoring for secrets-a and secrets-b instances",
  "tags": ["convocate", "openbao", "secrets", "vault"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "schemaVersion": 39,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["10s", "30s", "1m", "5m", "15m"]
  },
  "templating": {
    "list": [
      {
        "name": "instance",
        "label": "Instance",
        "type": "custom",
        "query": "secrets-a,secrets-b",
        "current": { "text": "secrets-a", "value": "secrets-a" },
        "options": [
          { "text": "secrets-a", "value": "secrets-a", "selected": true },
          { "text": "secrets-b", "value": "secrets-b", "selected": false }
        ],
        "includeAll": true,
        "allValue": "secrets-.*"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Seal Status",
      "description": "Whether the instance is sealed (1 = sealed, 0 = unsealed)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "UNSEALED", "color": "green" }, "1": { "text": "SEALED", "color": "red" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "vault_core_unsealed{instance=~\"$instance\"} == 0",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Token Count",
      "description": "Number of active tokens",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 500 },
              { "color": "red", "value": 1000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "vault_token_count{instance=~\"$instance\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Active Leases",
      "description": "Number of active leases",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "vault_expire_num_leases{instance=~\"$instance\"}",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Request Rate",
      "description": "Requests per second",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(rate(vault_core_handle_request_count{instance=~\"$instance\"}[5m]))",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "PKI Cert Issuance Rate",
      "description": "PKI certificate issuance rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(rate(vault_secret_kv_count{instance=~\"$instance\",mount_point=~\"pki.*\"}[5m]))",
          "legendFormat": "Certs/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Policy Evaluations",
      "description": "Policy evaluation rate",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(rate(vault_core_check_token_count{instance=~\"$instance\"}[5m]))",
          "legendFormat": "Evals/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Request Rate Over Time",
      "description": "Request rate over time by instance",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "expr": "rate(vault_core_handle_request_count{instance=~\"$instance\"}[5m])",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Request Duration",
      "description": "Request duration percentiles (p50, p95, p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(vault_core_handle_request_duration_seconds_bucket{instance=~\"$instance\"}[5m])) by (le)) * 1000",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(vault_core_handle_request_duration_seconds_bucket{instance=~\"$instance\"}[5m])) by (le)) * 1000",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(vault_core_handle_request_duration_seconds_bucket{instance=~\"$instance\"}[5m])) by (le)) * 1000",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 9,
      "title": "Auth Method Usage",
      "description": "Authentication attempts by method",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "stacking": { "mode": "normal" },
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "expr": "sum by (auth_method) (rate(vault_core_handle_login_request_count{instance=~\"$instance\"}[5m]))",
          "legendFormat": "{{auth_method}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "Token and Lease Count Over Time",
      "description": "Active tokens and leases over time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "expr": "vault_token_count{instance=~\"$instance\"}",
          "legendFormat": "{{instance}} tokens",
          "refId": "A"
        },
        {
          "expr": "vault_expire_num_leases{instance=~\"$instance\"}",
          "legendFormat": "{{instance}} leases",
          "refId": "B"
        }
      ]
    },
    {
      "id": 11,
      "title": "Audit Log Rate",
      "description": "Audit log entries per second",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "expr": "sum by (type) (rate(vault_audit_log_request_count{instance=~\"$instance\"}[5m]))",
          "legendFormat": "Request {{type}}",
          "refId": "A"
        },
        {
          "expr": "sum by (type) (rate(vault_audit_log_response_count{instance=~\"$instance\"}[5m]))",
          "legendFormat": "Response {{type}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 12,
      "title": "PKI Certificate Issuance Over Time",
      "description": "PKI certificate issuance rate over time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "expr": "rate(vault_secret_kv_count{instance=~\"$instance\",mount_point=~\"pki.*\"}[5m])",
          "legendFormat": "{{instance}} {{mount_point}}",
          "refId": "A"
        }
      ]
    }
  ]
}
