{
  "uid": "cloudflared-tunnel",
  "id": null,
  "title": "Cloudflared - Tunnel Stats",
  "description": "Cloudflared tunnel monitoring with connection, request, and latency metrics",
  "tags": ["convocate", "cloudflared", "tunnel"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "schemaVersion": 39,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["10s", "30s", "1m", "5m", "15m"]
  },
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(cloudflared_tunnel_active_streams, instance)",
        "current": {},
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "allValue": ".*"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Tunnel Status",
      "description": "Current tunnel connection status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "cloudflared_tunnel_active_streams{instance=~\"$instance\"} > 0 or vector(0)",
          "legendFormat": "Status",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Active Connections",
      "description": "Number of active tunnel connections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "green", "value": 2 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "cloudflared_tunnel_active_streams{instance=~\"$instance\"}",
          "legendFormat": "Connections",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Request Rate",
      "description": "Requests per second through the tunnel",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(rate(cloudflared_tunnel_total_requests{instance=~\"$instance\"}[5m]))",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Bytes Transmitted",
      "description": "Total bytes transmitted through tunnel",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(rate(cloudflared_tunnel_response_bytes_total{instance=~\"$instance\"}[5m])) + sum(rate(cloudflared_tunnel_request_bytes_total{instance=~\"$instance\"}[5m]))",
          "legendFormat": "Total",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Request Rate Over Time",
      "description": "Request throughput over time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "expr": "sum(rate(cloudflared_tunnel_total_requests{instance=~\"$instance\"}[5m]))",
          "legendFormat": "Total Requests",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Response Status Codes",
      "description": "Response status code distribution (2xx, 4xx, 5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "stacking": { "mode": "normal" },
            "lineWidth": 1
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "2xx" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "4xx" },
            "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "5xx" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "expr": "sum(rate(cloudflared_tunnel_response_by_code{instance=~\"$instance\",status_code=~\"2..\"}[5m]))",
          "legendFormat": "2xx",
          "refId": "A"
        },
        {
          "expr": "sum(rate(cloudflared_tunnel_response_by_code{instance=~\"$instance\",status_code=~\"4..\"}[5m]))",
          "legendFormat": "4xx",
          "refId": "B"
        },
        {
          "expr": "sum(rate(cloudflared_tunnel_response_by_code{instance=~\"$instance\",status_code=~\"5..\"}[5m]))",
          "legendFormat": "5xx",
          "refId": "C"
        }
      ]
    },
    {
      "id": 7,
      "title": "Request Duration",
      "description": "Request duration percentiles (p50, p95, p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(cloudflared_tunnel_request_duration_seconds_bucket{instance=~\"$instance\"}[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(cloudflared_tunnel_request_duration_seconds_bucket{instance=~\"$instance\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(cloudflared_tunnel_request_duration_seconds_bucket{instance=~\"$instance\"}[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 8,
      "title": "Bytes Transmitted Over Time",
      "description": "Bytes transmitted and received through the tunnel",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "lineWidth": 1
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Transmitted" },
            "properties": [{ "id": "custom.transform", "value": "negative-Y" }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "expr": "sum(rate(cloudflared_tunnel_request_bytes_total{instance=~\"$instance\"}[5m]))",
          "legendFormat": "Received",
          "refId": "A"
        },
        {
          "expr": "sum(rate(cloudflared_tunnel_response_bytes_total{instance=~\"$instance\"}[5m]))",
          "legendFormat": "Transmitted",
          "refId": "B"
        }
      ]
    }
  ]
}
