{
  "uid": "convocate-api",
  "title": "Convocate API",
  "description": "Convocate API service metrics: HTTP traffic, latency, errors, Go runtime, and connection pools",
  "tags": ["convocate", "api", "go"],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(up{job=~\".*api.*\"}, namespace)",
        "current": { "text": "convocate", "value": "convocate" },
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "HTTP Request Rate",
      "description": "Requests per second by method and path",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{namespace=\"$namespace\", job=~\".*api.*\"}[5m])) by (method, handler)",
          "legendFormat": "{{method}} {{handler}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "id": 2,
      "title": "HTTP Response Latency",
      "description": "Response latency percentiles (p50, p95, p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{namespace=\"$namespace\", job=~\".*api.*\"}[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{namespace=\"$namespace\", job=~\".*api.*\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{namespace=\"$namespace\", job=~\".*api.*\"}[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "id": 3,
      "title": "HTTP Error Rate (4xx)",
      "description": "Client error responses per second",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{namespace=\"$namespace\", job=~\".*api.*\", code=~\"4..\"}[5m])) by (code)",
          "legendFormat": "{{code}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 },
          "color": { "mode": "fixed", "fixedColor": "orange" }
        }
      }
    },
    {
      "id": 4,
      "title": "HTTP Error Rate (5xx)",
      "description": "Server error responses per second",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{namespace=\"$namespace\", job=~\".*api.*\", code=~\"5..\"}[5m])) by (code)",
          "legendFormat": "{{code}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 },
          "color": { "mode": "fixed", "fixedColor": "red" }
        }
      }
    },
    {
      "id": 5,
      "title": "Active Connections",
      "description": "Current active HTTP connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(http_active_connections{namespace=\"$namespace\", job=~\".*api.*\"})",
          "legendFormat": "active connections",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "id": 6,
      "title": "Goroutines",
      "description": "Number of active goroutines",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "go_goroutines{namespace=\"$namespace\", job=~\".*api.*\"}",
          "legendFormat": "goroutines",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "id": 7,
      "title": "Heap Memory",
      "description": "Go heap memory allocation",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "go_memstats_heap_alloc_bytes{namespace=\"$namespace\", job=~\".*api.*\"}",
          "legendFormat": "heap alloc",
          "refId": "A"
        },
        {
          "expr": "go_memstats_heap_inuse_bytes{namespace=\"$namespace\", job=~\".*api.*\"}",
          "legendFormat": "heap in-use",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "id": 8,
      "title": "GC Duration",
      "description": "Go garbage collection pause duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(go_gc_duration_seconds_sum{namespace=\"$namespace\", job=~\".*api.*\"}[5m])",
          "legendFormat": "gc duration rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "id": 9,
      "title": "PostgreSQL Connection Pool",
      "description": "Database connection pool statistics",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "pgx_pool_acquire_count_total{namespace=\"$namespace\", job=~\".*api.*\"}",
          "legendFormat": "acquired",
          "refId": "A"
        },
        {
          "expr": "pgx_pool_idle_connections{namespace=\"$namespace\", job=~\".*api.*\"}",
          "legendFormat": "idle",
          "refId": "B"
        },
        {
          "expr": "pgx_pool_in_use_connections{namespace=\"$namespace\", job=~\".*api.*\"}",
          "legendFormat": "in-use",
          "refId": "C"
        },
        {
          "expr": "pgx_pool_max_connections{namespace=\"$namespace\", job=~\".*api.*\"}",
          "legendFormat": "max",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "id": 10,
      "title": "Redis Connection Pool",
      "description": "Redis connection pool statistics",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "redis_pool_idle_connections{namespace=\"$namespace\", job=~\".*api.*\"}",
          "legendFormat": "idle",
          "refId": "A"
        },
        {
          "expr": "redis_pool_active_connections{namespace=\"$namespace\", job=~\".*api.*\"}",
          "legendFormat": "active",
          "refId": "B"
        },
        {
          "expr": "redis_pool_total_connections{namespace=\"$namespace\", job=~\".*api.*\"}",
          "legendFormat": "total",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    }
  ]
}
