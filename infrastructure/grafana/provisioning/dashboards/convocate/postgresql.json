{
  "uid": "convocate-postgresql",
  "title": "Convocate PostgreSQL",
  "description": "Convocate PostgreSQL metrics: connections, queries, transactions, cache, replication, and resource usage",
  "tags": ["convocate", "postgresql", "database"],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "namespace",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(pg_up, namespace)",
        "current": { "text": "convocate", "value": "convocate" },
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Active Connections",
      "description": "Current active PostgreSQL connections by state",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(pg_stat_activity_count{namespace=\"$namespace\"}) by (state)",
          "legendFormat": "{{state}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "id": 2,
      "title": "Query Rate",
      "description": "Queries executed per second",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(pg_stat_database_xact_commit{namespace=\"$namespace\"}[5m])) + sum(rate(pg_stat_database_xact_rollback{namespace=\"$namespace\"}[5m]))",
          "legendFormat": "queries/sec",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "id": 3,
      "title": "Transaction Rate",
      "description": "Commits and rollbacks per second",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(pg_stat_database_xact_commit{namespace=\"$namespace\"}[5m]))",
          "legendFormat": "commits/sec",
          "refId": "A"
        },
        {
          "expr": "sum(rate(pg_stat_database_xact_rollback{namespace=\"$namespace\"}[5m]))",
          "legendFormat": "rollbacks/sec",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "id": 4,
      "title": "Database Size",
      "description": "Total database size on disk",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(pg_database_size_bytes{namespace=\"$namespace\"}) by (datname)",
          "legendFormat": "{{datname}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "id": 5,
      "title": "Replication Lag",
      "description": "Replication lag in bytes (if replication is configured)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "pg_replication_lag{namespace=\"$namespace\"}",
          "legendFormat": "replication lag",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "id": 6,
      "title": "Cache Hit Ratio",
      "description": "Buffer cache hit ratio (higher is better)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(pg_stat_database_blks_hit{namespace=\"$namespace\"}) / (sum(pg_stat_database_blks_hit{namespace=\"$namespace\"}) + sum(pg_stat_database_blks_read{namespace=\"$namespace\"}))",
          "legendFormat": "cache hit ratio",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 },
          "thresholds": {
            "steps": [
              { "value": null, "color": "red" },
              { "value": 0.9, "color": "yellow" },
              { "value": 0.99, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Slow Queries",
      "description": "Queries with duration exceeding thresholds",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(pg_stat_activity_count{namespace=\"$namespace\", state=\"active\", wait_event_type=\"Lock\"}) or vector(0)",
          "legendFormat": "waiting on lock",
          "refId": "A"
        },
        {
          "expr": "sum(rate(pg_stat_statements_mean_time_seconds{namespace=\"$namespace\"}[5m])) by (query)",
          "legendFormat": "avg duration: {{query}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "id": 8,
      "title": "Container CPU Usage",
      "description": "CPU usage of PostgreSQL container pods",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"$namespace\", container=~\".*postgresql.*|.*postgres.*|.*pg.*\"}[5m])) by (pod)",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "id": 9,
      "title": "Container Memory Usage",
      "description": "Memory usage of PostgreSQL container pods",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=\"$namespace\", container=~\".*postgresql.*|.*postgres.*|.*pg.*\"}) by (pod)",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    }
  ]
}
