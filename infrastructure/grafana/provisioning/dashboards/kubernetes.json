{
  "uid": "k8s-clusters",
  "id": null,
  "title": "Kubernetes Clusters",
  "description": "Cluster-a and cluster-b node status, pod counts, resource usage, Cilium health, and ESO sync status",
  "tags": ["convocate", "kubernetes", "cilium", "eso"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "schemaVersion": 39,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["10s", "30s", "1m", "5m", "15m"]
  },
  "templating": {
    "list": [
      {
        "name": "cluster",
        "type": "custom",
        "current": { "text": "cluster-a", "value": "cluster-a" },
        "options": [
          { "text": "cluster-a", "value": "cluster-a", "selected": true },
          { "text": "cluster-b", "value": "cluster-b", "selected": false }
        ],
        "includeAll": true,
        "multi": true,
        "query": "cluster-a,cluster-b"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Node Status (Ready / NotReady)",
      "description": "Number of nodes in Ready vs NotReady state",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 4 },
              { "color": "green", "value": 6 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "count(kube_node_status_condition{condition=\"Ready\",status=\"true\",cluster=~\"$cluster\"})",
          "legendFormat": "Ready Nodes"
        }
      ]
    },
    {
      "id": 2,
      "title": "NotReady Nodes",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "count(kube_node_status_condition{condition=\"Ready\",status=\"false\",cluster=~\"$cluster\"}) or vector(0)",
          "legendFormat": "NotReady Nodes"
        }
      ]
    },
    {
      "id": 3,
      "title": "Pod Count by Namespace",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "count by (namespace) (kube_pod_info{cluster=~\"$cluster\"})",
          "legendFormat": "{{ namespace }}"
        }
      ]
    },
    {
      "id": 4,
      "title": "CPU Usage per Node",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "1 - avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\",cluster=~\"$cluster\"}[5m]))",
          "legendFormat": "{{ instance }}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Memory Usage per Node",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "node_memory_MemTotal_bytes{cluster=~\"$cluster\"} - node_memory_MemAvailable_bytes{cluster=~\"$cluster\"}",
          "legendFormat": "{{ instance }} used"
        }
      ]
    },
    {
      "id": 6,
      "title": "Cilium Agent Health",
      "description": "Cilium agent endpoint health across cluster nodes",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 12 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "count(cilium_agent_api_process_time_seconds_count{cluster=~\"$cluster\"} > 0)",
          "legendFormat": "Healthy Agents"
        }
      ]
    },
    {
      "id": 7,
      "title": "Cilium Policy Enforcement",
      "description": "Number of endpoints with policy enforcement active",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 12 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "sum by (instance) (cilium_policy_endpoint_enforcement_status{cluster=~\"$cluster\"})",
          "legendFormat": "{{ instance }}"
        }
      ]
    },
    {
      "id": 8,
      "title": "Cilium Drops",
      "description": "Packet drops by reason across Cilium agents",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 12 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "sum by (reason) (rate(cilium_drop_count_total{cluster=~\"$cluster\"}[5m]))",
          "legendFormat": "{{ reason }}"
        }
      ]
    },
    {
      "id": 9,
      "title": "ESO Sync Status",
      "description": "External Secrets sync success and failure counts",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 16 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "externalsecret_sync_calls_error{cluster=~\"$cluster\"} or vector(0)",
          "legendFormat": "Sync Errors"
        }
      ]
    },
    {
      "id": 10,
      "title": "ESO Synced Secrets",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 16 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "externalsecret_status_condition{condition=\"Ready\",status=\"True\",cluster=~\"$cluster\"}",
          "legendFormat": "{{ name }}"
        }
      ]
    },
    {
      "id": 11,
      "title": "Disk Usage per Node",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "1 - (node_filesystem_avail_bytes{mountpoint=\"/\",cluster=~\"$cluster\"} / node_filesystem_size_bytes{mountpoint=\"/\",cluster=~\"$cluster\"})",
          "legendFormat": "{{ instance }}"
        }
      ]
    },
    {
      "id": 12,
      "title": "Pod Restarts",
      "description": "Pods with restart counts in the last hour",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sort_desc(sum by (namespace, pod) (increase(kube_pod_container_status_restarts_total{cluster=~\"$cluster\"}[1h])) > 0)",
          "legendFormat": "{{ namespace }}/{{ pod }}",
          "format": "table",
          "instant": true
        }
      ]
    }
  ]
}
