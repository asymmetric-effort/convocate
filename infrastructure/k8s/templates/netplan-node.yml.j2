# Dual-NIC netplan configuration for {{ inventory_hostname }}
# enp1s0: cluster bridge network ({{ cluster_network }})
# enp2s0: LAN network via macvtap (192.168.3.0/24)
network:
  version: 2
  renderer: networkd
  ethernets:
    enp1s0:
      dhcp4: false
      addresses:
        - {{ cluster_ip }}/24
      routes:
        - to: {{ cluster_network }}
          scope: link
      nameservers:
        addresses:
          - 1.1.1.1
          - 8.8.8.8
    enp2s0:
      dhcp4: false
      addresses:
        - {{ lan_ip }}/24
      routes:
        - to: default
          via: 192.168.3.1
      nameservers:
        addresses:
          - 192.168.3.1
