# Traefik Helm values for {{ cluster_name }}
# Ingress controller with TLS termination for Convocate services.

# Use upstream image for K8s infrastructure install (no GHCR pull secret needed)
# deploy-apps.yml handles app-level container updates via GHCR
image:
  registry: docker.io
  repository: traefik
  tag: v3.7

deployment:
  replicas: 1

nodeSelector:
  kubernetes.io/hostname: {{ traefik_node }}

tolerations:
  - key: node-role.kubernetes.io/control-plane
    operator: Exists
    effect: NoSchedule

service:
  type: ClusterIP

ports:
  web:
    port: 8080
    expose:
      default: false
  websecure:
    port: 8443
    hostPort: 443
    expose:
      default: true
    tls:
      enabled: true

providers:
  kubernetesCRD:
    enabled: true
    allowCrossNamespace: false
    namespaces:
      - convocate
  kubernetesIngress:
    enabled: true
    namespaces:
      - convocate

ingressRoute:
  dashboard:
    enabled: false

logs:
  general:
    level: INFO
