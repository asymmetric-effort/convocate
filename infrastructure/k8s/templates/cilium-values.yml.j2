# Cilium Helm values for {{ cluster_name }}
# Replaces kube-proxy, provides mTLS service mesh via OpenBao PKI CA.

kubeProxyReplacement: true

k8sServiceHost: "{{ hostvars[groups['control_plane_primary'][0]].ansible_host }}"
k8sServicePort: 6443

ipam:
  mode: kubernetes

# Enable encryption between all pods via WireGuard
encryption:
  enabled: true
  type: wireguard
  wireguard:
    userspaceFallback: false

# Hubble observability
hubble:
  enabled: true
  relay:
    enabled: true
  ui:
    enabled: true
  metrics:
    enabled:
      - dns
      - drop
      - tcp
      - flow
      - icmp
      - http
    serviceMonitor:
      enabled: false

# Prometheus metrics
prometheus:
  enabled: true
  port: 9962
  serviceMonitor:
    enabled: false

operator:
  prometheus:
    enabled: true
    port: 9963
    serviceMonitor:
      enabled: false

# Enable socket-level load balancing for hostNetwork pods to reach ClusterIP services
socketLB:
  enabled: true
  hostNamespaceOnly: true

bpf:
  lbExternalClusterIP: true

# Pod CIDR
cluster:
  name: {{ cluster_name }}

# BGP and L2 announcements disabled (not needed for libvirt)
bgpControlPlane:
  enabled: false

# Enable host firewall for CIS compliance
hostFirewall:
  enabled: true

# Policy enforcement
policyEnforcementMode: default
