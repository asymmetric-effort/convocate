services:
  cloudflared:
    image: cloudflare/cloudflared:latest
    container_name: cloudflared
    restart: unless-stopped
    command: tunnel --config /etc/cloudflared/config.yml run
    volumes:
      - /opt/cloudflared/config.yml:/etc/cloudflared/config.yml:ro
      - /opt/cloudflared/credentials.json:/etc/cloudflared/credentials.json:ro
    network_mode: host
    cap_add:
      - NET_ADMIN
