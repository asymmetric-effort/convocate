tunnel: {{ cloudflare_tunnel_id }}
credentials-file: /etc/cloudflared/credentials.json

ingress:
  # OpenBao test (secrets-a)
  - hostname: dev.auth.asymmetric-effort.com
    service: https://192.168.3.160:443
    originRequest:
      noTLSVerify: true

  # OpenBao production (secrets-b)
  - hostname: auth.asymmetric-effort.com
    service: https://192.168.3.161:443
    originRequest:
      noTLSVerify: true

  # Grafana pre-production (grafana-a)
  - hostname: grafana-dev.asymmetric-effort.com
    service: https://192.168.3.162:443
    originRequest:
      noTLSVerify: true

  # Grafana production (grafana-b)
  - hostname: grafana.asymmetric-effort.com
    service: https://192.168.3.163:443
    originRequest:
      noTLSVerify: true

  # SSH access to svr00
  - hostname: ssh.asymmetric-effort.com
    service: ssh://192.168.3.159:22

  # Catch-all (required by cloudflared)
  - service: http_status:404
