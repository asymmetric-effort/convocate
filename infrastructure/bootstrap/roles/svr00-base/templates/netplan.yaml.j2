# svr00 network configuration
# Physical NIC: enp4s0f0 bridged to br0
# VMs attach to br0 and get their own LAN IPs directly
# 192.168.3.160-169 are reserved for core services on svr00
network:
  version: 2
  renderer: networkd
  ethernets:
    enp4s0f0:
      dhcp4: false
      dhcp6: false
  bridges:
    br0:
      interfaces:
        - enp4s0f0
      addresses:
        - 192.168.3.159/24  # svr00 ssh
        - 192.168.3.160/24  # core: secrets-a (openbao test)
        - 192.168.3.161/24  # core: secrets-b (openbao prod)
        - 192.168.3.162/24  # core: grafana-a
        - 192.168.3.163/24  # core: grafana-b
        - 192.168.3.164/24  # core: prometheus-a
        - 192.168.3.165/24  # core: prometheus-b
        - 192.168.3.166/24  # core: logs-a (victorialogs canary)
        - 192.168.3.167/24  # core: logs-b (victorialogs prod)
        - 192.168.3.168/24  # core: saml-scim-agent-a (canary)
        - 192.168.3.169/24  # core: saml-scim-agent-b (prod)
        - 192.168.3.190/24
        - 192.168.3.191/24
        - 192.168.3.192/24
      routes:
        - to: default
          via: 192.168.3.1
      nameservers:
        addresses:
          - 192.168.3.1
      parameters:
        stp: false
        forward-delay: 0
